# Copy this file to .env and fill in your values
# NEVER commit .env to git

# YouTube Data API v3 key (for competitor channel analysis)
# Get it at: https://console.cloud.google.com/apis/credentials
YT_API_KEY=your_youtube_data_api_key_here

# OAuth credentials are handled via client_secret.json (see README)
# No additional env vars needed for Analytics API
